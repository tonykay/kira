# --- Build tmux from source (not in UBI9 repos) ---
FROM registry.access.redhat.com/ubi9/ubi AS tmux-builder
RUN dnf install -y gcc make libevent-devel ncurses-devel && \
    curl -fsSL https://github.com/tmux/tmux/releases/download/3.3a/tmux-3.3a.tar.gz | tar xzf - && \
    cd tmux-3.3a && ./configure && make -j$(nproc) && make install DESTDIR=/tmux-out

# --- Main image ---
FROM registry.access.redhat.com/ubi9/ubi

# Enable EPEL for ripgrep, bat
RUN dnf install -y https://dl.fedoraproject.org/pub/epel/epel-release-latest-9.noarch.rpm && \
    dnf clean all

# Base system tools
RUN dnf install -y --allowerasing \
    curl wget bind-utils iputils nmap-ncat tcpdump \
    jq less vim-minimal git openssh-clients \
    postgresql \
    ripgrep bat \
    nodejs npm \
    libevent ncurses \
    && dnf clean all

# tmux from build stage
COPY --from=tmux-builder /tmux-out/usr/local/bin/tmux /usr/local/bin/tmux

# Neovim (latest stable from GitHub — EPEL version is too old for LazyVim)
RUN ARCH=$(uname -m) && \
    curl -fsSL "https://github.com/neovim/neovim/releases/latest/download/nvim-linux-${ARCH}.tar.gz" \
    | tar xzf - -C /opt && \
    ln -sf /opt/nvim-linux-${ARCH}/bin/nvim /usr/local/bin/nvim

# uv (brings Python 3.13 and pip-compatible installs)
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

# Python 3.13 via uv + Deep Agents library
RUN uv python install 3.13 && \
    uv venv /opt/deepagents --python 3.13 && \
    VIRTUAL_ENV=/opt/deepagents uv pip install deepagents langchain-openai awxkit && \
    chmod a+x /root && \
    chmod -R a+rX /root/.local/share/uv /opt/deepagents && \
    ln -sf /opt/deepagents/bin/python3 /usr/local/bin/python3.13

# yq (YAML processor)
RUN curl -fsSL https://github.com/mikefarah/yq/releases/latest/download/yq_linux_$(uname -m | sed 's/x86_64/amd64/;s/aarch64/arm64/') \
    -o /usr/local/bin/yq && chmod +x /usr/local/bin/yq

# ttyd
RUN ARCH=$(uname -m | sed 's/x86_64/x86_64/;s/aarch64/aarch64/') && \
    curl -fsSL "https://github.com/tsl0922/ttyd/releases/latest/download/ttyd.${ARCH}" \
    -o /usr/local/bin/ttyd && chmod +x /usr/local/bin/ttyd

# kubectl
RUN curl -fsSL "https://dl.k8s.io/release/$(curl -L -s https://dl.k8s.io/release/stable.txt)/bin/linux/$(uname -m | sed 's/x86_64/amd64/;s/aarch64/arm64/')/kubectl" \
    -o /usr/local/bin/kubectl && chmod +x /usr/local/bin/kubectl

# oc (OpenShift CLI)
RUN ARCH=$(uname -m | sed 's/x86_64/amd64/;s/aarch64/arm64/') && \
    curl -fsSL "https://mirror.openshift.com/pub/openshift-v4/${ARCH}/clients/ocp/stable/openshift-client-linux.tar.gz" \
    | tar xzf - -C /usr/local/bin oc kubectl.1 2>/dev/null; \
    chmod +x /usr/local/bin/oc

# Claude Code
RUN npm install -g @anthropic-ai/claude-code

# Create dev user
RUN useradd --create-home --uid 1001 --shell /bin/bash dev && \
    mkdir -p /home/dev/.local/bin /artifacts && \
    chown -R dev:dev /home/dev /artifacts

# LazyVim setup for dev user
RUN git clone https://github.com/LazyVim/starter /home/dev/.config/nvim && \
    rm -rf /home/dev/.config/nvim/.git && \
    chown -R dev:dev /home/dev/.config

# tmux config
COPY deploy/tmux.conf /home/dev/.tmux.conf
RUN chown dev:dev /home/dev/.tmux.conf

# Deep Agents CLI for dev user
RUN su - dev -c "uv tool install deepagents-cli --python 3.13"

# Shell prompt and PATH for dev user
RUN echo 'export PATH="/home/dev/.local/bin:/opt/deepagents/bin:$PATH"' >> /home/dev/.bashrc && \
    echo 'export PS1="\[\e[32m\]sre\[\e[0m\]:\[\e[34m\]\w\[\e[0m\]\$ "' >> /home/dev/.bashrc && \
    echo '[ -n "$TICKET_ID" ] && echo -e "\e[33m Ticket: $TICKET_TITLE\e[0m" && echo -e "\e[36m   Area: $TICKET_AREA | Systems: $AFFECTED_SYSTEMS\e[0m" && echo -e "\e[36m   Artifacts: /artifacts/$TICKET_ID/\e[0m"' >> /home/dev/.bashrc

# Copy entrypoint and session scripts
COPY deploy/ttyd-entrypoint.sh /usr/local/bin/ttyd-entrypoint.sh
COPY deploy/ttyd-session.sh /usr/local/bin/ttyd-session.sh
RUN chmod +x /usr/local/bin/ttyd-entrypoint.sh /usr/local/bin/ttyd-session.sh

USER dev
WORKDIR /home/dev

EXPOSE 7681

ENTRYPOINT ["ttyd-entrypoint.sh"]
